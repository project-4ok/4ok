POSTGRES_PASSWORD=replace-with-postgres-password
GCB_DATABASE_URL=postgresql+psycopg://gcb:replace-with-password@postgres:5432/gcb
GCB_GMAIL_INFISICAL_PROJECT_ID=replace-with-project-id
GCB_GMAIL_INFISICAL_ENV=prod
GCB_GMAIL_INFISICAL_PATH=/gmail-pilot
GCB_EMBEDDING_PROVIDER=openai
GCB_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GCB_EMBEDDING_DIMENSIONS=256
OPENAI_API_KEY=replace-with-openai-api-key
INFISICAL_API_URL=https://replace-with-infisical-host
INFISICAL_CLIENT_ID=replace-with-machine-client-id
INFISICAL_CLIENT_SECRET=replace-with-machine-client-secret
