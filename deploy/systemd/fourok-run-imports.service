[Unit]
Description=4ok scheduled import
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
WorkingDirectory=/opt/4ok
Environment=GCB_IMAGE_TAG=replace-with-commit-hash
Environment=GCB_CONFIG_PATH=/opt/4ok/.local/4ok.toml
EnvironmentFile=/etc/4ok/4ok.env
ExecStart=/usr/bin/docker compose run --rm app run-imports --connector gmail-singer --singer-file /var/lib/4ok/raw/gmail/tap-gmail-output.jsonl --database-url ${GCB_DATABASE_URL} --config /etc/4ok/4ok.toml
