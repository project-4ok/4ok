# Pinned 4OK runtime artifact contract consumed by deployment repositories.
# Replace placeholders with values from runtime-manifest.json produced by publish-runtime.
FOUR_OK_GIT_SHA=<full git sha>
FOUR_OK_CLI_WHEEL_URL=https://github.com/project-fourok/fourok/releases/download/v0.1.0/fourok-0.1.0-py3-none-any.whl
FOUR_OK_CLI_WHEEL_SHA256=<wheel sha256>
FOUR_OK_APP_IMAGE=ghcr.io/project-fourok/fourok-app@sha256:<digest>
FOUR_OK_DAGSTER_CODE_IMAGE=ghcr.io/project-fourok/fourok-dagster-code@sha256:<digest>
FOUR_OK_DAGSTER_RUNTIME_IMAGE=docker.io/dagster/dagster-k8s:1.13.8@sha256:24661edd6c98705eba61823804afab65ecd4691bf74a697b7c0d0659df5ed301
