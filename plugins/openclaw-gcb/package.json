{
  "name": "@4ok/gcb-openclaw-plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "Local 4ok tools for OpenClaw.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "dependencies": {
    "@sinclair/typebox": "^0.32.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.22"
  },
  "openclaw": {
    "plugin": "./openclaw.plugin.json",
    "extensions": [
      "./dist/index.js"
    ],
    "build": {
      "openclawVersion": ">=2026.3.22"
    },
    "compat": {
      "pluginApi": ">=2026.3.22"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json"
  }
}
