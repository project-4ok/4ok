# 4ok local runtime configuration
# Copy to .env and fill only the connectors you want to run.

# Core
FOUR_OK_DATABASE_URL=
FOUR_OK_DOTENV_PATH=.env
FOUR_OK_LOAD_DOTENV=true
OPENAI_API_KEY=

# Slack
SLACK_BOT_TOKEN=
TAP_SLACK_SELECTED_CHANNELS=
TAP_SLACK_START_DATE=

# Linear
LINEAR_API_KEY=
LINEAR_GRAPHQL_URL=https://api.linear.app/graphql
LINEAR_LIMIT=1000

# Twenty CRM
TWENTY_API_KEY=
TWENTY_BASE_URL=
TWENTY_LIMIT=1000

# Google Drive
GOOGLE_WORKSPACE_OAUTH_CLIENT_SECRET_JSON=
GOOGLE_WORKSPACE_OAUTH_REFRESH_TOKEN=
GOOGLE_WORKSPACE_DRIVE_IDS=
GOOGLE_WORKSPACE_LIMIT=100
